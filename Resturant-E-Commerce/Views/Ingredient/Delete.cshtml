@model Ingredient

@{
    ViewBag.Title = $"Ingredient {Model.Name} Details";
}

<h3>Are you sure you want to delete this ingredient?</h3>

<div>
    <h4>@Model.Name</h4>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="IngredientId" value="@Model.IngredientId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Details" asp-route-id="@Model.IngredientId" class="btn btn-secondary">Back to Details</a>
    </form>
</div>
