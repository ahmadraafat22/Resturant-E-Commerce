@model Ingredient
@{
	ViewBag.Title = "Ingredient Details";
}

<h1>@Model.Name Details</h1>

<div class="card">
    <div class="card-header">
        <h4>@Model.Name</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Ingredient ID</dt>
            <dd class="col-sm-9">@Model.IngredientId</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>
        </dl>
    </div>
</div>

@if (Model.ProductIngredients != null && Model.ProductIngredients.Any())
{
    <h3 class="mt-4">Related Products</h3>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Product ID</th>
                <th>Product Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pi in Model.ProductIngredients)
            {
                <tr>
                    <td>@pi.ProductId</td>
                    <td>@pi.Product?.Name</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="mt-4 text-muted">No related products found.</p>
}
<br />
<br />
<a asp-action="Delete" asp-route-id="@Model.IngredientId" class="btn btn-danger">Delete this Ingredient </a>
<br />
<a asp-action="Edit" asp-route-id="@Model.IngredientId" class="btn btn-dark">Edit Ingredient </a>
<br />
<a asp-action="Index" class="btn btn-primary">Back to list</a>